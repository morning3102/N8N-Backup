      "parameters": {
        "jsCode": "const requiredColumns = [\n      'หมายเลขคำสั่งซื้อ',\n      'สถานะการสั่งซื้อ',\n      'สถานะการคืนเงินหรือคืนสินค้า',\n      'เลขอ้างอิง SKU (SKU Reference No.)',\n      'ชื่อสินค้า',\n      'ช่องทางการชำระเงิน',\n      'จำนวน', \n      'จำนวนที่ส่งคืน',\n      'ราคาตั้งต้น',\n      'ราคาขายสุทธิ', \n      'โค้ดส่วนลดชำระโดยผู้ขาย',\n      'วันที่ทำการสั่งซื้อ',\n      'เวลาส่งสินค้า'\n]\n\n// รับข้อมูล Input\nconst items = $input.all();\nconst returnData = [];\n\n// กำหนดชื่อ Platform ตายตัวสำหรับ Node นี้\nconst currentPlatform = 'Shopee';\n\n// 🛡️ PART 1: VALIDATION CHECK\n// เช็คว่ามีข้อมูลไหม\nif (!items.length || !items[0].json) {\n  // แทนที่จะ throw เรา return ค่า Error ออกไปตรงๆ\n  return [{\n    json: {\n      error: true,\n      errorMessage: `⚠️ [${currentPlatform}] ไม่พบข้อมูล Input (Empty Dataset)`\n    }\n  }];\n}\n\nconst firstRow = items[0].json;\nconst actualKeys = Object.keys(firstRow).map(k => k.trim().toLowerCase());\n\n// หาคอลัมน์ที่หาย\nconst missingColumns = requiredColumns.filter(reqCol => {\n  return !actualKeys.includes(reqCol.toLowerCase());\n});\n\n// 🚨 ถ้าเจอคอลัมน์หาย\nif (missingColumns.length > 0) {\n  const missingList = missingColumns.join(', ');\n  // ส่งออกไปบอก Node ถัดไปว่า \"ฉันพังนะ\" พร้อมข้อความเต็มๆ\n  return [{\n    json: {\n      error: true,\n      errorMessage: `⚠️ [${currentPlatform}] ข้อมูลไม่ครบ! ขาดคอลัมน์: ${missingList}`\n    }\n  }];\n}\n\n// ⚙️ PART 2: TRANSFORMATION\nfor (const item of items) {\n  const row = item.json; \n  \n  // Helper Function\n  const get = (colName) => {\n    if (!colName) return null;\n    const key = Object.keys(row).find(k => k.trim().toLowerCase() === colName.trim().toLowerCase());\n    return key ? row[key] : null;\n  };\n\n  // Logic การแปลงข้อมูลเฉพาะของ SHOPEE\n  const originalPrice = parseFloat(get('ราคาตั้งต้น')) || 0;\n  const netPrice = parseFloat(get('ราคาขายสุทธิ')) || 0;\n   \n  const finalRow = {\n      \"Platform name\": currentPlatform,\n      \"Order ID\": get('หมายเลขคำสั่งซื้อ'),\n      \"Order status\": get('สถานะการสั่งซื้อ'),\n      \"Cancelation/Return Type\": get('สถานะการคืนเงินหรือคืนสินค้า'),\n      \"Seller SKU\": get('เลขอ้างอิง SKU (SKU Reference No.)'),\n      \"Product Name\": get('ชื่อสินค้า'),\n      \"Payment Method\": get('ช่องทางการชำระเงิน'),\n      \"Quantity\": parseInt(get('จำนวน')) || 0, \n      \"Quantity of return\": get('จำนวนที่ส่งคืน'),\n      \"SKU Unit Original Price\": originalPrice,\n      \"SKU Subtotal Before Discount\": netPrice,\n      \"SKU Subtotal After Discount\": null,\n      \"Direct Discount\": originalPrice - netPrice, \n      \"Voucher Discount\": get('โค้ดส่วนลดชำระโดยผู้ขาย'),\n      \"Created Time\": get('วันที่ทำการสั่งซื้อ'),\n      \"Delivered Time\": get('เวลาส่งสินค้า')\n  };\n\n  // Push ข้อมูล\n  returnData.push({ json: finalRow });\n}\n\nreturn returnData;"
      },
